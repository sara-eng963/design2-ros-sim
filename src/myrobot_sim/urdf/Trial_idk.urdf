<!-- TRANSMISSIONS -->

<transmission name="FL_Wheel_trans">
  <type>transmission_interface/SimpleTransmission</type>
  <joint name="FL_Wheel_Joint">
    <hardwareInterface>velocity</hardwareInterface>
  </joint>
  <actuator name="FL_Wheel_motor">
    <hardwareInterface>velocity</hardwareInterface>
    <mechanicalReduction>1</mechanicalReduction>
  </actuator>
</transmission>

<transmission name="RL_Wheel_trans">
  <type>transmission_interface/SimpleTransmission</type>
  <joint name="RL_Wheel_Joint">
    <hardwareInterface>velocity</hardwareInterface>
  </joint>
  <actuator name="RL_Wheel_motor">
    <hardwareInterface>velocity</hardwareInterface>
    <mechanicalReduction>1</mechanicalReduction>
  </actuator>
</transmission>

<transmission name="RR_Wheel_trans">
  <type>transmission_interface/SimpleTransmission</type>
  <joint name="RR_Wheel_Joint">
    <hardwareInterface>velocity</hardwareInterface>
  </joint>
  <actuator name="RR_Wheel_motor">
    <hardwareInterface>velocity</hardwareInterface>
    <mechanicalReduction>1</mechanicalReduction>
  </actuator>
</transmission>

<transmission name="FR_Wheel_trans">
  <type>transmission_interface/SimpleTransmission</type>
  <joint name="FR_Wheel_Joint">
    <hardwareInterface>velocity</hardwareInterface>
  </joint>
  <actuator name="FR_Wheel_motor">
    <hardwareInterface>velocity</hardwareInterface>
    <mechanicalReduction>1</mechanicalReduction>
  </actuator>
</transmission>



  <ros2_control name="RobotSystem" type="system">
<hardware>
<plugin>gz_ros2_control/GazeboSimSystem</plugin>
</hardware>
<joint name="FR_Wheel_Joint">
<command_interface name="velocity">
<param name="min">-10</param>
<param name="max">10</param>
</command_interface>
<state_interface name="velocity"/>
<state_interface name="position"/>
</joint>
<joint name="FL_Wheel_Joint">
<command_interface name="velocity">
<param name="min">-10</param>
<param name="max">10</param>
</command_interface>
<state_interface name="velocity"/>
<state_interface name="position"/>
</joint>
<joint name="RL_Wheel_Joint">
<command_interface name="velocity">
<param name="min">-10</param>
<param name="max">10</param>
</command_interface>
<state_interface name="velocity"/>
<state_interface name="position"/>
</joint>
<joint name="RR_Wheel_Joint">
<command_interface name="velocity">
<param name="min">-10</param>
<param name="max">10</param>
</command_interface>
<state_interface name="velocity"/>
<state_interface name="position"/>
</joint>

<joint name="Arm_Joint">
  <command_interface name="position"/>
  <state_interface name="position"/>
</joint>
</ros2_control>
<!--Adding the sensor IMU-->
<link name="imu_link">
<inertial>
   <mass value="0.05"/>
  <origin xyz="0 0 0" rpy="0 0 0"/>
  <inertia ixx="1e-5" ixy="0" ixz="0"
            iyy="1e-5" iyz="0"
            izz="1e-5"/>
</inertial>
<visual>
<geometry>
<box size="0.02 0.02 0.01"/>
</geometry>
</visual>
<collision>
<geometry>
<box size="0.02 0.02 0.01"/>
</geometry>
</collision>
</link>
<joint name="imu_joint" type="fixed">
<parent link="base_link"/>
<child link="imu_link"/>
<origin xyz="0 0 0.05" rpy="0 0 0"/>
</joint>
<link name="ultrasonic_center_link">
<visual>
<geometry>
<cylinder radius="0.03" length="0.05"/>
</geometry>
</visual>
<collision>
<geometry>
<cylinder radius="0.03" length="0.05"/>
</geometry>
</collision>
<inertial>
<mass value="0.1"/>
<origin xyz="0 0 0" rpy="0 0 0"/>
<inertia ixx="1e-5" ixy="0" ixz="0"
iyy="1e-5" iyz="0"
izz="1e-5"/>
</inertial>
</link>
<joint name="ultrasonic_center_joint" type="fixed">
<parent link="base_link"/>
<child link="ultrasonic_center_link"/>
<origin xyz="0.15 0 -0.1" rpy="0 0 0"/>
</joint>

<link name="ultrasonic_left_link">
<visual>
<geometry>
<cylinder radius="0.03" length="0.05"/>
</geometry>
</visual>
<collision>
<geometry>
<cylinder radius="0.03" length="0.05"/>
</geometry>
</collision>
<inertial>
<mass value="0.1"/>
<origin xyz="0 0 0" rpy="0 0 0"/>
<inertia ixx="1e-5" ixy="0" ixz="0"
iyy="1e-5" iyz="0"
izz="1e-5"/>
</inertial>
</link>
<joint name="ultrasonic_left_joint" type="fixed">
<parent link="base_link"/>
<child link="ultrasonic_left_link"/>
<origin xyz="0.128 0.115 -0.1" rpy="0 0 0.5236"/>
</joint>

<link name="ultrasonic_right_link">
<visual>
<geometry>
<cylinder radius="0.03" length="0.05"/>
</geometry>
</visual>
<collision>
<geometry>
<cylinder radius="0.03" length="0.05"/>
</geometry>
</collision>
<inertial>
<mass value="0.1"/>
<origin xyz="0 0 0" rpy="0 0 0"/>
<inertia ixx="1e-5" ixy="0" ixz="0"
iyy="1e-5" iyz="0"
izz="1e-5"/>
</inertial>
</link>
<joint name="ultrasonic_right_joint" type="fixed">
<parent link="base_link"/>
<child link="ultrasonic_right_link"/>
<origin xyz="0.128 -0.115 -0.1" rpy="0 0 -0.5236"/>
</joint>
<gazebo>
<plugin filename="gz_ros2_control-system"
name="gz_ros2_control::GazeboSimROS2ControlPlugin">
<parameters>
/home/sara/design2_ws/install/myrobot_sim/share/myrobot_sim/config/controllers.yaml
</parameters>
</plugin>
</gazebo>
<!--Adding IMU Sensor Plugin-->
<gazebo reference="imu_link">
<sensor name="imu_sensor" type="imu">
<always_on>true</always_on>
<update_rate>50</update_rate>
<topic>imu</topic>
<gz_frame_id>imu_link</gz_frame_id>
<plugin
filename="gz-sim-imu-system"
name="gz::sim::systems::Imu"/>
</sensor>
</gazebo>
<gazebo reference="ultrasonic_center_link">
<sensor name="ultrasonic_center" type="gpu_lidar">
<update_rate>50</update_rate>
<topic>scan</topic>
<ray>
  <scan>
    <horizontal>
      <samples>30</samples>
      <resolution>1</resolution>
      <min_angle>-0.2618</min_angle>
      <max_angle>0.2618</max_angle>
    </horizontal>
    <vertical>
      <samples>1</samples>
      <resolution>1</resolution>
      <min_angle>0</min_angle>
      <max_angle>0</max_angle>
    </vertical>
  </scan>
  <range>
    <min>0.08</min>
    <max>10.0</max>
    <resolution>0.01</resolution>
  </range>
</ray>
<always_on>1</always_on>
<visualize>true</visualize>
</sensor>
</gazebo>

<gazebo reference="ultrasonic_left_link">
<sensor name="ultrasonic_left" type="gpu_lidar">
<update_rate>50</update_rate>
<topic>scan_left</topic>
